# Telegram Bot Token (from @BotFather)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Telegram Supergroup Chat ID (negative number, e.g. -1001234567890)
# The group must have "Topics" enabled and the bot must be an admin
TELEGRAM_GROUP_ID=your_supergroup_id_here

# Optional: only forward messages from specific WhatsApp numbers (comma-separated, e.g. 1234567890,9876543210)
# Leave empty to forward from all contacts
WHATSAPP_ALLOWED_NUMBERS=

# Session data directory for WhatsApp authentication persistence
WHATSAPP_SESSION_DIR=./.wwebjs_auth

# Web UI port (default: 3000)
PORT=3000
